{
  "name": "trello-board",
  "version": "1.0.0",
  "description": "Multi-tenant Trello-style Kanban board for team collaboration",
  "private": true,
  "scripts": {
    "dev": "node server/index.js",
    "migrate": "npx knex migrate:latest",
    "migrate:rollback": "npx knex migrate:rollback",
    "seed": "npx knex seed:run",
    "setup": "npm install && npx knex migrate:latest && npx knex seed:run",
    "test": "jest"
  },
  "dependencies": {
    "@google-cloud/logging": "^11.2.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
